---
const roles = [
  {
    dates: 'Aug 2018 – Apr 2026',
    role: 'Staff Software Engineer · former Tech Lead',
    org: 'Templafy',
    note: 'C#/.NET, Azure, AKS, DDD, event-driven microservices; AI infrastructure and technical leadership.',
  },
  {
    dates: 'Oct 2015 – Aug 2018',
    role: 'Senior Back-End Developer',
    org: 'Charlie Tango (KMD)',
    note: 'Client-facing delivery across multi-country sites; C#/.NET, Azure, SQL Server.',
  },
  {
    dates: 'Jul 2012 – Sep 2015',
    role: 'Senior Software Developer',
    org: 'Shatel',
    note: 'Scaled the platform from 500k to 900k+ users; proposed simpler, often better implementations.',
  },
  {
    dates: 'Feb 2010 – Jul 2012',
    role: 'Senior Software Engineer',
    org: 'NHTC',
    note: 'Built in-house and client-facing software, and coached junior developers. .NET Framework, SQL Server, SharePoint.',
  },
];

const credentials = [
  { name: 'Certified Developer', issuer: 'EPiServer (Optimizely)', year: '2018', award: false },
  { name: '“Best Implementation of the Year”', issuer: 'EPiServer Award', year: '', award: true },
  { name: 'MCSD — Solutions Developer', issuer: 'Microsoft', year: '2019', award: false },
  { name: 'MCAD — Application Developer', issuer: 'Microsoft', year: '2021', award: false },
];
---

<section id="experience" class="reveal scroll-mt-16 border-t border-line dark:border-night-line">
  <div class="mx-auto max-w-5xl px-6 py-16 sm:py-20">
    <p class="font-mono text-xs uppercase tracking-[0.22em] text-clay">04 — Experience</p>
    <h2 class="mt-3 font-display text-3xl font-semibold tracking-tight text-ink dark:text-night-text">
      Career
    </h2>
    <div class="mt-5 h-[3px] w-14 rounded-full bg-clay"></div>

    <ol class="mt-10 max-w-3xl">
      {
        roles.map((r, i) => (
          <li class="flex gap-5">
            <div class="flex flex-col items-center">
              <span class="mt-1.5 size-3 shrink-0 rounded-full bg-clay shadow-[0_0_0_4px_var(--color-clay-soft)] dark:shadow-[0_0_0_4px_rgba(222,91,59,0.18)]" />
              {i < roles.length - 1 && <span class="my-1 w-0.5 flex-1 bg-line dark:bg-night-line" />}
            </div>
            <div class="pb-9">
              <div class="font-mono text-xs text-faint dark:text-night-faint">{r.dates}</div>
              <div class="mt-1.5 font-display text-lg font-semibold text-ink dark:text-night-text">
                {r.role}
              </div>
              <div class="text-muted dark:text-night-muted">{r.org}</div>
              <p class="mt-2 max-w-xl text-sm leading-relaxed text-muted dark:text-night-muted">
                {r.note}
              </p>
            </div>
          </li>
        ))
      }
    </ol>

    <a
      href="/cv/ashkan-sirous-cv.pdf"
      class="inline-flex items-center rounded-lg border border-ink/20 px-5 py-2.5 text-sm font-medium text-ink transition hover:border-ink hover:bg-ink hover:text-white dark:border-night-line dark:text-night-text dark:hover:bg-night-surface"
    >
      Download CV (PDF) ↓
    </a>

    <div class="mt-16">
      <p class="font-mono text-xs uppercase tracking-[0.22em] text-clay">Credentials &amp; honours</p>
      <div class="mt-5 grid grid-cols-1 gap-3 sm:grid-cols-2">
        {
          credentials.map((c) => (
            <div
              class={`flex items-center gap-4 rounded-xl border bg-card p-4 dark:bg-night-surface ${c.award ? 'border-clay/40' : 'border-line dark:border-night-line'}`}
            >
              <span
                class={`grid size-11 shrink-0 place-items-center rounded-full ${c.award ? 'bg-clay text-white' : 'bg-clay/10 text-clay'}`}
              >
                {c.award ? (
                  <svg class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M8 21h8M12 17v4M7 4h10v5a5 5 0 0 1-10 0V4z" />
                    <path d="M7 4H4v2a3 3 0 0 0 3 3M17 4h3v2a3 3 0 0 1-3 3" />
                  </svg>
                ) : (
                  <svg class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <circle cx="12" cy="9" r="6" />
                    <path d="M9 14.5 8 22l4-2 4 2-1-7.5" />
                  </svg>
                )}
              </span>
              <div class="min-w-0">
                <div class="font-display text-sm font-semibold text-ink dark:text-night-text">{c.name}</div>
                <div class="font-mono text-xs text-faint dark:text-night-faint">
                  {c.issuer}{c.year ? ` · ${c.year}` : ''}
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
