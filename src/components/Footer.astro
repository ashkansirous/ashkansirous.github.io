---
const year = new Date().getFullYear();

const links = [
  { href: 'mailto:ashkan.sirous@gmail.com', label: 'Email' },
  { href: 'https://github.com/ashkansirous', label: 'GitHub' },
  { href: 'https://linkedin.com/in/ashkansirous', label: 'LinkedIn' },
];
---

<footer id="contact" class="reveal scroll-mt-16 border-t border-line dark:border-night-line">
  <div class="mx-auto max-w-5xl px-6 py-16 sm:py-20">
    <p class="font-mono text-xs uppercase tracking-[0.22em] text-clay">06 — Contact</p>
    <h2 class="mt-3 font-display text-3xl font-semibold tracking-tight text-ink dark:text-night-text">
      Get in touch
    </h2>
    <div class="mt-5 h-[3px] w-14 rounded-full bg-clay"></div>

    <p class="mt-8 max-w-2xl text-lg leading-relaxed text-muted dark:text-night-muted">
      Open to interesting conversations. The fastest way to reach me is email.
    </p>
    <a
      href="mailto:ashkan.sirous@gmail.com"
      class="mt-6 inline-flex items-center rounded-lg bg-clay px-5 py-2.5 text-sm font-medium text-white transition hover:bg-clay-deep"
    >
      ashkan.sirous@gmail.com
    </a>

    <div
      class="mt-14 flex flex-col items-start justify-between gap-4 border-t border-line pt-8 font-mono text-xs text-faint sm:flex-row sm:items-center dark:border-night-line dark:text-night-faint"
    >
      <p>© {year} Ashkan Sirous</p>
      <div class="flex flex-wrap gap-x-5 gap-y-2">
        {
          links.map((link) => (
            <a href={link.href} class="transition hover:text-clay">
              {link.label}
            </a>
          ))
        }
      </div>
    </div>
  </div>
</footer>
