---
import ThemeToggle from './ThemeToggle.astro';

const navLinks = [
  { href: '#about', label: 'About' },
  { href: '#contact', label: 'Contact' },
];
---

<header
  class="sticky top-0 z-50 border-b border-slate-200/80 bg-white/80 backdrop-blur-md dark:border-slate-800/80 dark:bg-slate-950/80"
>
  <nav class="mx-auto flex h-16 max-w-3xl items-center justify-between px-6">
    <a
      href="#top"
      class="font-semibold tracking-tight text-slate-900 transition hover:text-sky-600 dark:text-slate-100 dark:hover:text-sky-400"
    >
      Ashkan Sirous
    </a>

    <div class="flex items-center gap-1 sm:gap-2">
      <ul class="hidden items-center gap-1 sm:flex">
        {
          navLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="rounded-md px-3 py-2 text-sm font-medium text-slate-600 transition hover:text-slate-900 dark:text-slate-400 dark:hover:text-slate-100"
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
      <ThemeToggle />
    </div>
  </nav>
</header>
