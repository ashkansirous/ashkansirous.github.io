---
import ThemeToggle from './ThemeToggle.astro';

const navLinks = [
  { href: '#about', label: 'About' },
  { href: '#work', label: 'Work' },
  { href: '#experience', label: 'Experience' },
  { href: '#contact', label: 'Contact' },
];
---

<header class="sticky top-0 z-50 bg-ink/95 backdrop-blur-md dark:bg-night-surface/95">
  <nav class="mx-auto flex h-16 max-w-5xl items-center justify-between px-6">
    <a href="#top" class="flex items-center gap-3">
      <span
        class="grid size-9 place-items-center rounded-lg bg-clay font-display text-base font-bold text-white"
      >
        A
      </span>
      <span class="flex flex-col leading-tight">
        <span class="font-display font-semibold tracking-tight text-white">Ashkan Sirous</span>
        <span class="font-mono text-[10px] uppercase tracking-[0.15em] text-band-sub">
          Staff Software Engineer
        </span>
      </span>
    </a>

    <div class="flex items-center gap-2 sm:gap-5">
      <ul class="hidden items-center gap-6 text-sm text-band-sub sm:flex">
        {
          navLinks.map((link) => (
            <li>
              <a href={link.href} class="transition hover:text-white">
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
      <ThemeToggle />
      <a
        href="#contact"
        class="hidden items-center rounded-lg bg-clay px-4 py-2 text-sm font-medium text-white transition hover:bg-clay-deep sm:inline-flex"
      >
        Get in touch
      </a>
    </div>
  </nav>
</header>
