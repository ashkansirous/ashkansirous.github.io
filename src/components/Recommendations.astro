---
// Lead pull-quote + a compact strip. Verbatim from LinkedIn recommendations.
const lead = {
  quote:
    'During incidents, he was someone you could genuinely count on: calm, sharp, and focused on solving the problem in the right way. His expertise in performance, scalability, and monitoring of complex systems, as well as his deep database knowledge repeatedly helped resolve difficult issues and close gaps in situations where others were stuck.',
  name: 'Dan Antal',
  title: 'Staff Engineer · ~7 years at Templafy',
  initials: 'DA',
  photo: 'https://media.licdn.com/dms/image/v2/D5603AQFWEnNp8ixw9g/profile-displayphoto-crop_800_800/B56ZoWZmTCJQAI-/0/1761312401084?e=1783555200&v=beta&t=M2Tbm0Y_P8maLk4at-_Ay1dUdXniqFR-40u1vllhepc',
};

const strip = [
  {
    name: 'René Gundersen',
    title: 'CTO · managed Ashkan at Templafy',
    theme: 'He has a rare ability to move effortlessly between high-level architecture and low-level implementation, quickly understanding how components fit together and identifying the right trade-offs. This made him a key contributor to our distributed architecture, where his impact was both significant and lasting.',
    initials: 'RG',
    photo: null,
  },
  {
    name: 'Flemming Humlum Søgaard',
    title: 'Product Manager · Templafy',
    theme: 'In refinements he was known for his drawings that would clarify the solutions we were refining and the constraints of the software… It was the same Ashkan I saw mentor and develop engineers, and turn each one of them into confident problem solvers.',
    initials: 'FH',
    photo: 'https://media.licdn.com/dms/image/v2/D4E03AQGOVhLnKx7IVg/profile-displayphoto-scale_100_100/B4EZ6B24dcI0AY-/0/1780295111541?e=1783555200&v=beta&t=J2nH_Iuv7Ddeiz_K3MsQ2o7rmWU0t4I8gyJ-tKgE1wk',
  },
  {
    name: 'Silvia Belloni',
    title: 'InfoSec & IT Governance Lead · Templafy',
    theme: 'What stood out was his ability to bring structure to complex areas like AI evaluation and data flows, translating risk considerations into scalable, production-ready systems.',
    initials: 'SB',
    photo: 'https://media.licdn.com/dms/image/v2/C4D03AQGg0lvHMV6WTQ/profile-displayphoto-shrink_800_800/profile-displayphoto-shrink_800_800/0/1656620946211?e=1783555200&v=beta&t=hgeuikLpkkCECtxNs-7eii0EXUkiYi7X_9s2gHLOAc0',
  },
  {
    name: 'Hossein Margani',
    title: 'DevOps Engineer · WTW',
    theme: 'Ashkan has a rare gift for bridging the gap between high-level business strategy and low-level system design. He consistently acts as a force multiplier for his organization. Any top-tier engineering team would be fortunate to have his vision and technical depth.',
    initials: 'HM',
    photo: 'https://media.licdn.com/dms/image/v2/D4E03AQEg_YDgU3gSMg/profile-displayphoto-shrink_800_800/B4EZclaDT1HsAg-/0/1748679276384?e=1783555200&v=beta&t=LyaWkB2kEVbDzRulM0UEO_Bfg4mRhOKQI-DKWA7j_Qw',
  },
];
---

<section id="recommendations" class="reveal scroll-mt-16 border-t border-line dark:border-night-line">
  <div class="mx-auto max-w-5xl px-6 py-16 sm:py-20">
    <p class="font-mono text-xs uppercase tracking-[0.22em] text-clay">05 — Recommendations</p>
    <h2 class="mt-3 font-display text-3xl font-semibold tracking-tight text-ink dark:text-night-text">
      What colleagues say
    </h2>
    <div class="mt-5 h-[3px] w-14 rounded-full bg-clay"></div>

    <figure
      class="mt-10 rounded-xl border border-line border-l-[3px] border-l-clay bg-card p-8 dark:border-night-line dark:border-l-clay dark:bg-night-surface"
    >
      <div class="font-display text-5xl leading-none text-clay">"</div>
      <blockquote class="mt-2 max-w-3xl font-display text-xl font-medium leading-relaxed text-ink dark:text-night-text">
        {lead.quote}
      </blockquote>
      <figcaption class="mt-6 flex items-center gap-3">
        {lead.photo ? (
          <img
            src={lead.photo}
            alt={lead.name}
            width="40"
            height="40"
            class="size-10 rounded-full object-cover"
            referrerpolicy="no-referrer"
          />
        ) : (
          <span class="grid size-10 place-items-center rounded-full bg-ink font-display text-sm font-semibold text-white">
            {lead.initials}
          </span>
        )}
        <span>
          <span class="block font-display font-semibold text-ink dark:text-night-text">{lead.name}</span>
          <span class="block text-sm text-faint dark:text-night-faint">{lead.title}</span>
        </span>
      </figcaption>
    </figure>

    <div class="mt-6 grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-4">
      {
        strip.map((r) => (
          <div class="rounded-xl border border-line bg-card p-6 dark:border-night-line dark:bg-night-surface">
            <p class="text-sm leading-relaxed text-muted dark:text-night-muted">{r.theme}</p>
            <div class="mt-5 flex items-center gap-3">
              {r.photo ? (
                <img
                  src={r.photo}
                  alt={r.name}
                  width="36"
                  height="36"
                  class="size-9 rounded-full object-cover"
                  referrerpolicy="no-referrer"
                />
              ) : (
                <span class="grid size-9 place-items-center rounded-full bg-ink font-display text-xs font-semibold text-white">
                  {r.initials}
                </span>
              )}
              <span>
                <span class="block font-display text-sm font-semibold text-ink dark:text-night-text">{r.name}</span>
                <span class="block text-xs text-faint dark:text-night-faint">{r.title}</span>
              </span>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
