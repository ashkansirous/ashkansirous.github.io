---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Page not found — Ashkan Sirous">
  <main class="grid min-h-dvh place-items-center px-6 text-center">
    <div>
      <p class="font-mono text-sm uppercase tracking-[0.22em] text-clay">404</p>
      <h1 class="mt-4 font-display text-4xl font-bold tracking-tight text-ink dark:text-night-text">
        Page not found
      </h1>
      <p class="mt-4 text-lg text-muted dark:text-night-muted">
        That page doesn’t exist. Let’s get you back.
      </p>
      <a
        href="/"
        class="mt-8 inline-flex items-center rounded-lg bg-clay px-5 py-2.5 text-sm font-medium text-white transition hover:bg-clay-deep"
      >
        ← Back home
      </a>
    </div>
  </main>
</Layout>
