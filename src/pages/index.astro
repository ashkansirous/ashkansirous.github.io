---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <main class="grid min-h-dvh place-items-center px-6">
    <section class="max-w-2xl text-center">
      <p class="mb-4 text-sm font-medium uppercase tracking-[0.2em] text-sky-400">
        Coming soon
      </p>
      <h1 class="text-balance text-4xl font-bold tracking-tight sm:text-6xl">
        Ashkan Sirous
      </h1>
      <p class="mt-4 text-lg text-slate-300 sm:text-xl">
        Staff Software Engineer — C#/.NET, Azure, distributed systems, and enterprise AI infrastructure.
      </p>
      <div class="mt-10 flex items-center justify-center gap-5 text-sm text-slate-400">
        <a class="transition hover:text-sky-400" href="https://github.com/ashkansirous">GitHub</a>
        <span aria-hidden="true">·</span>
        <a class="transition hover:text-sky-400" href="https://linkedin.com/in/ashkansirous">LinkedIn</a>
        <span aria-hidden="true">·</span>
        <a class="transition hover:text-sky-400" href="mailto:ashkan.sirous@gmail.com">Email</a>
      </div>
    </section>
  </main>
</Layout>
